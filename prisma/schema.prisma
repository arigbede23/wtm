generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EventSource {
  USER
  EVENTBRITE
  TICKETMASTER
}

enum EventCategory {
  MUSIC
  SPORTS
  ARTS
  FOOD
  TECH
  SOCIAL
  COMEDY
  WELLNESS
  OUTDOORS
  NIGHTLIFE
  COMMUNITY
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum RSVPStatus {
  GOING
  INTERESTED
  NOT_GOING
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  username    String?  @unique
  displayName String?
  avatarUrl   String?
  bio         String?
  interests   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizedEvents Event[]      @relation("organizer")
  rsvps           RSVP[]
  savedEvents     SavedEvent[]

  @@map("users")
}

model Event {
  id            String        @id @default(uuid())
  source        EventSource   @default(USER)
  externalId    String?
  title         String
  description   String?
  category      EventCategory @default(OTHER)
  address       String?
  city          String?
  state         String?
  lat           Float?
  lng           Float?
  startDate     DateTime
  endDate       DateTime?
  coverImageUrl String?
  isFree        Boolean       @default(true)
  price         Float?
  url           String?
  organizerId   String?
  organizer     User?         @relation("organizer", fields: [organizerId], references: [id])
  status        EventStatus   @default(PUBLISHED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  rsvps       RSVP[]
  savedEvents SavedEvent[]

  @@unique([source, externalId])
  @@index([startDate])
  @@index([category])
  @@index([city])
  @@map("events")
}

model RSVP {
  id        String     @id @default(uuid())
  userId    String
  eventId   String
  status    RSVPStatus
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("rsvps")
}

model SavedEvent {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("saved_events")
}
