// Prisma Schema — this is the "source of truth" for your database structure.
// Prisma reads this file to create/update your database tables and generate
// a type-safe client you can use in your code.
// Docs: https://www.prisma.io/docs/concepts/components/prisma-schema

// This tells Prisma to generate a JavaScript/TypeScript client we can import
generator client {
  provider = "prisma-client-js"
}

// This connects Prisma to our Supabase PostgreSQL database.
// The actual URLs are stored in .env (not committed to git for security).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")    // Used at runtime (pooled connection)
  directUrl = env("DIRECT_URL")      // Used for migrations (direct connection)
}

// --- ENUMS ---
// Enums are like dropdown menus — they restrict a field to specific values.

// Where did this event come from?
enum EventSource {
  USER          // Created by a user on our app
  EVENTBRITE    // Imported from Eventbrite API (Phase 4)
  TICKETMASTER  // Imported from Ticketmaster API (Phase 4)
  INSTAGRAM     // Discovered from Instagram hashtags
}

// What type of event is it?
enum EventCategory {
  MUSIC
  SPORTS
  ARTS
  FOOD
  TECH
  SOCIAL
  COMEDY
  WELLNESS
  OUTDOORS
  NIGHTLIFE
  COMMUNITY
  OTHER
}

// Is the event live, still being edited, or cancelled?
enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

// How is the user responding to an event?
enum RSVPStatus {
  GOING
  INTERESTED
  NOT_GOING
}

// What kind of notification is it?
enum NotificationType {
  NEW_FOLLOWER
  FRIEND_GOING
  FRIEND_INTERESTED
  EVENT_UPDATED
  EVENT_INVITE
}

// What's the status of an invite?
enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// --- MODELS ---
// Each model becomes a table in the database.
// The fields become columns. The types (String, Int, etc.) define what data they hold.

// A user of the app
model User {
  id          String   @id @default(uuid())   // Unique ID, auto-generated
  email       String   @unique                // Must be unique — no duplicate accounts
  username    String?  @unique                // Optional display username (? = optional)
  displayName String?                         // Their preferred name to show
  avatarUrl   String?                         // Profile picture URL
  bio         String?                         // Short bio text
  interests   String[] @default([])           // Array of interest tags, e.g. ["music", "food"]
  createdAt   DateTime @default(now())        // Auto-set when the user is created
  updatedAt   DateTime @updatedAt             // Auto-updated whenever the user record changes

  embedding   Unsupported("vector(1536)")?  // OpenAI embedding for recommendations

  // Relations — these connect User to other tables
  organizedEvents Event[]      @relation("organizer")  // Events this user created
  rsvps           RSVP[]                               // Events they've RSVP'd to
  savedEvents     SavedEvent[]                          // Events they've bookmarked
  comments        Comment[]                             // Comments this user posted
  commentLikes    CommentLike[]                         // Comments this user liked

  // Social relations
  followers          Follow[]        @relation("following") // People who follow this user
  following          Follow[]        @relation("follower")  // People this user follows
  notifications      Notification[]  @relation("notificationRecipient")
  actedNotifications Notification[]  @relation("notificationActor")
  sentInvites        Invite[]        @relation("inviteSender")
  receivedInvites    Invite[]        @relation("inviteRecipient")
  pushSubscriptions  PushSubscription[]

  @@map("users")  // The actual table name in Postgres (lowercase convention)
}

// An event that users can discover and attend
model Event {
  id            String        @id @default(uuid())
  source        EventSource   @default(USER)        // Where the event came from
  externalId    String?                              // ID from external API (for deduplication)
  title         String                               // Event name
  description   String?                              // Details about the event
  category      EventCategory @default(OTHER)        // What kind of event
  address       String?                              // Street address
  city          String?
  state         String?
  lat           Float?                               // Latitude for map display
  lng           Float?                               // Longitude for map display
  startDate     DateTime                             // When the event starts
  endDate       DateTime?                            // When it ends (optional)
  coverImageUrl String?                              // Hero image URL
  isFree        Boolean       @default(true)         // Is it free?
  price         Float?                               // Ticket price (if not free)
  url           String?                              // External link (e.g. ticket page)
  organizerId   String?                              // Who created it (FK to User)
  organizer     User?         @relation("organizer", fields: [organizerId], references: [id])
  status        EventStatus   @default(PUBLISHED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  embedding     Unsupported("vector(1536)")?  // OpenAI embedding for recommendations

  // Relations
  rsvps         RSVP[]
  savedEvents   SavedEvent[]
  notifications Notification[]   // Notifications referencing this event
  comments      Comment[]
  invites       Invite[]

  @@unique([source, externalId])  // Prevents duplicate imports from the same API
  @@index([startDate])            // Makes sorting by date fast
  @@index([category])             // Makes filtering by category fast
  @@index([city])                 // Makes filtering by city fast
  @@map("events")
}

// Tracks a user's response to an event (Going / Interested / Not Going)
model RSVP {
  id        String     @id @default(uuid())
  userId    String
  eventId   String
  status    RSVPStatus
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations — connect to User and Event tables
  // onDelete: Cascade means if the user or event is deleted, their RSVPs are too
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])  // One RSVP per user per event
  @@map("rsvps")
}

// Tracks events a user has bookmarked/saved for later
model SavedEvent {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])  // Can only save an event once
  @@map("saved_events")
}

// Tracks who follows whom
model Follow {
  id          String   @id @default(uuid())
  followerId  String                          // The user who is following
  followingId String                          // The user being followed
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])  // Can only follow someone once
  @@map("follows")
}

// Notifications for social events (new follower, friend going to event, etc.)
model Notification {
  id        String           @id @default(uuid())
  userId    String                                // Who receives this notification
  actorId   String                                // Who triggered it
  type      NotificationType                      // What kind of notification
  eventId   String?                               // Related event (optional)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user  User   @relation("notificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User   @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// A comment on an event
model Comment {
  id        String   @id @default(uuid())
  text      String
  pinned    Boolean  @default(false)
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  likes CommentLike[]

  @@index([eventId, createdAt])
  @@map("comments")
}

// Tracks likes on comments
model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])  // One like per user per comment
  @@map("comment_likes")
}

// Browser push notification subscriptions
model PushSubscription {
  id       String @id @default(uuid())
  userId   String
  endpoint String
  p256dh   String
  auth     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])  // One subscription per endpoint per user
  @@map("push_subscriptions")
}

// Event invitations from one user to another
model Invite {
  id          String       @id @default(uuid())
  eventId     String
  senderId    String
  recipientId String
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sender    User  @relation("inviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User  @relation("inviteRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([eventId, senderId, recipientId])  // One invite per sender-recipient-event combo
  @@index([recipientId])
  @@map("invites")
}
